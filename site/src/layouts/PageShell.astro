---
/*
 * PageShell — the layout for STANDARD marketing pages (Terms, Privacy, the case
 * study, the product pages). It stamps the shared chrome — the <TopBar> header and
 * the <Footer> — around a <slot>, inside the Base document shell, so a page is just
 * its own content. Header + footer come from the ONE component library, so editing
 * them updates every page (and the design-system showcase) at once.
 *
 * The landing page does NOT use this: its footer lives inside the ScrollStage as
 * the closing scroll group's floor, so index.astro composes Base + TopBar + Landing
 * directly. A standard page has a normal-flow footer at the bottom instead.
 *
 * Chrome is the GLOBAL variant (System · Product · Service · View Demo · Get
 * Started; footer mirrors + Terms · Privacy · support), the same header/footer as
 * every other page. Get Started routes to the home fork (/#fork, the default).
 * The sticky header takes flow space, so <slot> content begins just below it.
 */
import Base from "./Base.astro"
import { TopBar } from "@/components/web/TopBar"
import { Footer } from "@/components/web/Footer"

interface Props {
  title?: string
  description?: string
}
const { title, description } = Astro.props
---

<Base title={title} description={description}>
  <TopBar client:load variant="global" />
  <main class="page-main" id="top">
    <slot />
  </main>
  <Footer client:load reveal variant="global" />
</Base>
