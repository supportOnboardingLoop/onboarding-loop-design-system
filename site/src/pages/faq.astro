---
/*
 * /faq — a centered FAQ accordion + a "still have questions" card, on the global
 * chrome. FaqPage is an island (client:load) for the accordion's single-open.
 */
import Base from "../layouts/Base.astro"
import { TopBar } from "@/components/web/TopBar"
import { Footer } from "@/components/web/Footer"
import FaqPage from "../FaqPage"
---

<Base
  title="FAQ · Onboarding Loop"
  description="Answers to the questions founders ask before they buy: what it is, who it's for, and how it works."
>
  <TopBar client:load variant="global" active="faq" />
  <main id="top">
    <FaqPage client:load />
  </main>
  <Footer client:load reveal variant="global" />
</Base>
