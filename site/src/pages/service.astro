---
/*
 * /service — Done for you, $1,500 → $750. Composes Base directly (not PageShell)
 * so it can use the GLOBAL header/footer variant. `active="service"` tints the
 * current link; getStartedHref="#buy" points the header's Get Started at this
 * page's buy card. `bodyClass="has-buybar"` reserves space for the fixed mobile
 * buy bar so it never hides the footer.
 */
import Base from "../layouts/Base.astro"
import { TopBar } from "@/components/web/TopBar"
import { Footer } from "@/components/web/Footer"
import ServicePage from "../ServicePage"
---

<Base
  title="Done for you · Onboarding Loop"
  description="I build your onboarding plan on your actual product: a blueprint, an interactive prototype of the first win, a build roadmap, and a live walkthrough, in three days. $750 while the case-study shelf builds."
  bodyClass="has-buybar"
>
  <TopBar client:load variant="global" active="service" getStartedHref="#buy" />
  <main id="top">
    <ServicePage client:load />
  </main>
  <Footer client:load reveal variant="global" />
</Base>
